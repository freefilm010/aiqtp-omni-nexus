# =============================================================================
# AIQTP Omni-Nexus — Environment Variables
# =============================================================================
# Copy to .env and fill in the values below.
# Never commit .env to git.
#
# Minimum required for self-hosted stack:
#   POSTGRES_PASSWORD, JWT_SECRET, ANON_KEY, SERVICE_ROLE_KEY
#
# Generate ANON_KEY and SERVICE_ROLE_KEY with:
#   node -e "const j=require('jsonwebtoken');console.log(j.sign({role:'anon'},process.env.JWT_SECRET||'changeme',{expiresIn:'10y'}))"
#   (change role to 'service_role' for SERVICE_ROLE_KEY)
# =============================================================================

# ── Supabase Core ─────────────────────────────────────────────────────────────
# Strong random password for PostgreSQL
POSTGRES_PASSWORD=aiqtp_secure_pass_change_me

# JWT secret — min 32 chars, random
JWT_SECRET=aiqtp-super-secret-jwt-min-32-chars-change-me

# Generated from JWT_SECRET (see above)
ANON_KEY=
SERVICE_ROLE_KEY=

# Public URL for auth redirects (set to your domain in production)
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3001

# ── Alpaca Trading ────────────────────────────────────────────────────────────
# Get from: alpaca.markets → Live account → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_PAPER_MODE=false

# Comma-separated whitelist of tradable symbols
ALPACA_SYMBOL_WHITELIST=BTCUSD,ETHUSD,SOLUSD,AVAXUSD,LINKUSD

# Set to true to enable live ccxt orders via trading-tools service
CCXT_LIVE_ENABLED=false

# ── RAG Service ───────────────────────────────────────────────────────────────
# Use Ollama (default, local) or OpenAI for embeddings/LLM
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=llama3

# Set to use OpenAI instead of Ollama
OPENAI_API_KEY=

# GitHub token for cloning private repos in repos.yaml
GITHUB_TOKEN=

# ── Trading Worker ────────────────────────────────────────────────────────────
# How often the worker polls for new directives (seconds)
LOOP_INTERVAL_SECONDS=60

# ── CoinGecko ─────────────────────────────────────────────────────────────────
# Optional — for live price feeds in the worker
COINGECKO_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Render (for deploy.sh) ────────────────────────────────────────────────────
# Get from: dashboard.render.com → Account → API Keys
RENDER_API_KEY=

# ── Supabase Management API (for deploy.sh) ───────────────────────────────────
# Get from: supabase.com/dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=

# ── Frontend service URLs (Vercel env vars) ───────────────────────────────────
# Render trading-service URL (for agent_directives + strategy_registry)
VITE_RENDER_WORKER_URL=https://aiqtp-trading-service.onrender.com
# Render quantum agent URL (for quantum circuit execution)
VITE_QUANTUM_AGENT_URL=https://aiqtp-quantum-agent.onrender.com

# ── IBM Quantum ────────────────────────────────────────────────────────────────
# Get from: quantum.ibm.com → Account → API token
IBM_QUANTUM_API_KEY=
IBM_QUANTUM_CRN=

# ── Anthropic (for edge functions outside Lovable.dev) ────────────────────────
# Set when deploying Supabase edge functions outside of Lovable environment
ANTHROPIC_API_KEY=

# Cache hashed assets aggressively (immutable, 1 year)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache fonts aggressively
*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML pages - no cache (always fresh)
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

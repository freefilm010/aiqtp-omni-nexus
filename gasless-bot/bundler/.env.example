# ─────────────────────────────────────────────────────────────────────────────
#  AIQTP Self-Hosted ERC-4337 Bundler — Environment Variables
#  Copy to .env and fill in all values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Arbitrum RPC ──────────────────────────────────────────────────────────────
# Public endpoint (rate-limited) or your own Arbitrum full node.
# Recommended: self-hosted Arbitrum Nitro node for production.
# See: https://docs.arbitrum.io/run-arbitrum-node/run-full-node
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Bundler wallet ────────────────────────────────────────────────────────────
# Address that receives gas reimbursements from the EntryPoint.
# Must hold a small ETH balance on Arbitrum for initial staking (≈ 0.01 ETH).
BUNDLER_BENEFICIARY=0xYourBundlerBeneficiaryAddressHere

# ── Port overrides (optional) ─────────────────────────────────────────────────
BUNDLER_PORT=3000
BUNDLER_PRIVATE_PORT=3001

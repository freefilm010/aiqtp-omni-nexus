# ─────────────────────────────────────────────────────────────
#  gasless-bot  –  Environment Variables
#  Copy this file to .env and fill in all values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────
# Arbitrum Mainnet RPC endpoint.
# Free options: https://arb1.arbitrum.io/rpc  (public, rate-limited)
# Recommended: Alchemy / Infura / QuickNode for production use.
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Pimlico ───────────────────────────────────────────────────
# Get a free API key at https://dashboard.pimlico.io
# Free tier: 1 M sponsored operations / month.
PIMLICO_API_KEY=your_pimlico_api_key_here

# ── Wallet ────────────────────────────────────────────────────
# Private key of the EOA that OWNS the Smart Account.
# This EOA signs UserOperations but never pays gas.
# The wallet 0xf77Ebc11C2bEe9e3ecefC13CB58CA261f6694c4F is the target.
PRIVATE_KEY=your_private_key_here

# ── Contract addresses (filled in after deployment) ───────────
# Address of the ERC-4337 SimpleAccount (Smart Contract Account).
# Run: python scripts/deploy_smart_account.py  to get this.
SMART_ACCOUNT_ADDRESS=

# Address of the deployed FlashLoanArbExecutor contract.
# Run: npx hardhat run scripts/deploy_executor.js --network arbitrum
EXECUTOR_ADDRESS=

# ── Optional tuning ───────────────────────────────────────────
# Minimum estimated profit (USD) before executing an arbitrage.
MIN_ARB_PROFIT_USD=10

# Minimum estimated liquidation bonus (USD) before liquidating.
MIN_LIQ_BONUS_USD=20

# How often to scan for opportunities (seconds).
SCAN_INTERVAL_SEC=12

# Maximum flash loan size (USD) to attempt.
MAX_FLASH_LOAN_USD=500000

# ── Optional: Arbiscan API key for contract verification ──────
ARBISCAN_API_KEY=your_arbiscan_api_key_here

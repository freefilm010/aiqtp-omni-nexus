# Arbitrum RPC endpoint
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Private key of the wallet that executes swaps (must hold ETH on Arbitrum)
ONRAMP_EXECUTOR_PRIVATE_KEY=your_private_key_here

# Shared secret for webhook authentication
ONRAMP_WORKER_SECRET=your_shared_secret_here

# HTTP port to listen on
PORT=8080
